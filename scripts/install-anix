#!/usr/bin/env bash
set -euo pipefail

repo_url="https://github.com/win0na/anix.git"
repo_tarball_url="https://github.com/win0na/anix/archive/refs/heads/main.tar.gz"
repo_remote_regex='(^|[[:space:]])(git@github\.com:|https://github\.com/|ssh://git@github\.com/)?win0na/anix(\.git)?($|[[:space:]])'
bootstrap_dir="${XDG_CACHE_HOME:-$HOME/.cache}/anix-bootstrap"
host="${1:-}"

is_valid_cached_repo() {
  local path="$1"
  if [[ -d "$path/.git" ]] && command -v git >/dev/null 2>&1 && git -C "$path" remote get-url origin >/dev/null 2>&1; then
    git -C "$path" remote get-url origin | grep -Eq "$repo_remote_regex" && return 0
  fi
  [[ -f "$path/flake.nix" && -f "$path/scripts/install-anix-local" ]] || return 1
  [[ -d "$path/.git" ]] && return 0
  [[ -f "$path/.anix-bootstrap-source" ]] && grep -qx 'win0na/anix' "$path/.anix-bootstrap-source"
}

refresh_cached_archive_checkout() {
  local staged_repo backup_repo
  command -v curl >/dev/null 2>&1 || return 1
  command -v tar >/dev/null 2>&1 || return 1
  tmp_tarball="$(mktemp "${TMPDIR:-/tmp}/anix-bootstrap.XXXXXX.tar.gz")"
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/anix-bootstrap.XXXXXX")"
  trap 'rm -rf -- "$tmp_tarball" "$tmp_dir"' EXIT
  curl -fsSL "$repo_tarball_url" -o "$tmp_tarball"
  tar -xzf "$tmp_tarball" -C "$tmp_dir"
  staged_repo="$tmp_dir/anix-main"
  [[ -d "$staged_repo" ]] || return 1
  printf '%s\n' 'win0na/anix' > "$staged_repo/.anix-bootstrap-source"
  backup_repo="$bootstrap_dir/repo.backup.$$"
  rm -rf -- "$backup_repo"
  if [[ -e "$bootstrap_dir/repo" ]]; then
    mv "$bootstrap_dir/repo" "$backup_repo"
  fi
  if ! mv "$staged_repo" "$bootstrap_dir/repo"; then
    rm -rf -- "$bootstrap_dir/repo"
    [[ -e "$backup_repo" ]] && mv "$backup_repo" "$bootstrap_dir/repo"
    return 1
  fi
  rm -rf -- "$backup_repo"
}
if [[ -z "$host" ]]; then
  case "$(uname -s)" in
    Darwin) host=amac ;;
    Linux)
      if [[ -n "${WSL_DISTRO_NAME:-}" || -f /proc/sys/fs/binfmt_misc/WSLInterop ]]; then
        host=apc
      else
        host=anix
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*) host=apc ;;
    *) echo "error: pass anix, apc, or amac explicitly" >&2; exit 1 ;;
  esac
fi

mkdir -p "$bootstrap_dir"
if [[ -d "$bootstrap_dir/repo/.git" ]]; then
  if is_valid_cached_repo "$bootstrap_dir/repo"; then
    if command -v git >/dev/null 2>&1; then
      git -C "$bootstrap_dir/repo" pull --ff-only || echo "warning: failed to refresh cached bootstrap checkout; using existing repo" >&2
    fi
  else
    refresh_cached_archive_checkout
  fi
elif is_valid_cached_repo "$bootstrap_dir/repo"; then
  refresh_cached_archive_checkout || echo "warning: failed to refresh cached archive bootstrap checkout; using existing repo" >&2
elif command -v git >/dev/null 2>&1; then
  rm -rf -- "$bootstrap_dir/repo"
  git clone "$repo_url" "$bootstrap_dir/repo"
else
  refresh_cached_archive_checkout || { echo "error: failed to refresh the anix bootstrap checkout" >&2; exit 1; }
fi

exec bash "$bootstrap_dir/repo/scripts/install-anix-local" "$host"
