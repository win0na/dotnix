#!/usr/bin/env bash
set -euo pipefail

repo_url="https://github.com/win0na/a.nix.git"
bootstrap_dir="${XDG_CACHE_HOME:-$HOME/.cache}/a.nix-bootstrap"
host="${1:-}"
if [[ -z "$host" ]]; then
  case "$(uname -s)" in
    Darwin) host=a.mac ;;
    Linux)
      if [[ -n "${WSL_DISTRO_NAME:-}" || -f /proc/sys/fs/binfmt_misc/WSLInterop ]]; then
        host=a.pc
      else
        host=a.nix
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*) host=a.pc ;;
    *) echo "error: pass a.nix, a.pc, or a.mac explicitly" >&2; exit 1 ;;
  esac
fi

mkdir -p "$bootstrap_dir"
if [[ -d "$bootstrap_dir/repo/.git" ]]; then
  git -C "$bootstrap_dir/repo" pull --ff-only
else
  git clone "$repo_url" "$bootstrap_dir/repo"
fi

exec bash "$bootstrap_dir/repo/scripts/install-anix-local" "$host"
