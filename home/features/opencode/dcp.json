{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": []
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": []
    }
  },
  "protectedFilePatterns": [
    "**/AGENTS.md",
    "**/llm/*.md",
    "**/TEXT_STYLE.md",
    "**/flake.nix",
    "**/common/system.nix",
    "**/home/common.nix"
  ],
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "maxContextLimit": 120000,
    "minContextLimit": 70000,
    "modelMaxLimits": {
      "openai/gpt-5.4": 320000,
      "openai/gpt-5.4-mini": 180000,
      "openai/gpt-5.3-codex": 180000,
      "anthropic/claude-opus-4-6": 140000,
      "anthropic/claude-sonnet-4-6": 120000,
      "opencode/gpt-5.4": 320000
    },
    "modelMinLimits": {
      "openai/gpt-5.4": 180000,
      "openai/gpt-5.4-mini": 100000,
      "openai/gpt-5.3-codex": 100000,
      "anthropic/claude-opus-4-6": 80000,
      "anthropic/claude-sonnet-4-6": 70000,
      "opencode/gpt-5.4": 180000
    },
    "nudgeFrequency": 4,
    "iterationNudgeThreshold": 12,
    "nudgeForce": "soft",
    "protectedTools": [
      "task",
      "skill",
      "todowrite",
      "todoread"
    ],
    "protectUserMessages": false
  }
}
