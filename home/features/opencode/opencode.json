{
  "$schema": "https://opencode.ai/config.json",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**"
    ]
  },
  "plugin": [
    "oh-my-openagent@latest",
    "@tarquinen/opencode-dcp@latest",
    "@sveltejs/opencode@latest",
    "opencode-gemini-auth@latest"
  ],
  "mcp": {
    "brightdata": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brightdata/mcp"
      ],
      "environment": {
        "API_TOKEN": "{env:BRIGHTDATA_API_KEY}"
      },
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tavily-mcp@latest"
      ],
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
      },
      "enabled": true
    }
  },
  "provider": {
    "lms": {
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-26b": {
          "name": "Google Gemma 4 (26B, Q8_0)",
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "google": {
      "options": {
        "projectId": "fabled-infinity-493002-t9"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
