{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "cooldown_seconds": 30,
    "timeout_seconds": 15
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking"
      ],
      "variant": "high"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.4"
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking"
      ],
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.4"
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "low",
      "prompt_append": "Research in phases with a finite budget. Avoid long runs of the same tool. After each search burst, synthesize what changed and either narrow the target or stop."
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.4"
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "low",
      "prompt_append": "Use bounded search. Do not do long runs of the same tool. After 5-7 search calls, switch to reading the best hits or summarize. If results stop improving, stop searching rather than repeating the same pattern."
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking",
        "openai/gpt-5.4-mini"
      ],
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking",
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking"
      ],
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking"
      ],
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking"
      ],
      "variant": "high"
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "high"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      //"model": "openai/gpt-5.4",
      "fallback_models": [
        //"opencode/gemini-3.1-pro",
        "openai/gpt-5.4"
      ],
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"opencode/gpt-5.4"
      ],
      "variant": "high"
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      //"model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking",
        //"opencode/gemini-3.1-pro",
        "openai/gpt-5.4"
      ],
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.4"
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "low"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "openai/gpt-5.4-mini"
        //"google/antigravity-claude-sonnet-4-6"
      ],
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        //"google/antigravity-claude-opus-4-6-thinking",
        //"opencode/gpt-5.4"
      ],
      "variant": "high"
    },
    "deep": {
      //"model": "google/antigravity-claude-opus-4-6-thinking",
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ],
      "variant": "high"
    },
    "writing": {
      //"model": "google/antigravity-gemini-3-flash",
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "opencode/gpt-5.4"
      ]
    }
  },
  "background_task": {
    "circuitBreaker": {
      "enabled": true,
      "consecutiveThreshold": 40,
      "maxToolCalls": 800
    }
  },
  "_migrations": [
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "gpt-centric-routing:primary-gpt-5.4-with-claude-high-lanes"
  ]
}
